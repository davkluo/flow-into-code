# Firebase Admin SDK (server-only — never expose publicly)
# Private key must be a single line with literal \n for newlines
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# OpenAI
OPENAI_API_KEY=

# Upstash Redis (server-only — for backend rate limiting on /api/chat)
# Create a database at upstash.com and copy the REST API credentials
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# GCP API Key for E2E tests (server-only)
FIREBASE_SERVER_API_KEY=